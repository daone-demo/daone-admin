{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "has": [{ "type": "host", "value": "admin.daoneai.com" }],
      "destination": "https://api.daoneai.com/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api-test.daoneai.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
